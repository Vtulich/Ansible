version: '3.7'
services:
  {{ service_name }}:
    container_name: {{ service_name }}
    image: "{{ services[service_name].special_image | default(default_image) }}"
    restart: unless-stopped
{% if service_name == 'smev4' %}
    user: "1000"
{% endif %}
    ports:
{% if services[service_name]['tcp_port'] is string %}
      - {{ services[service_name]['tcp_port'] }}
{% else %}
{% for port in services[service_name]['tcp_port'] %}
      - {{ port }}
{% endfor %}
{% endif %}
{% if services[service_name]['grpc_port'] is defined %}
      - {{ services[service_name]['grpc_port'] }}
{% endif %}
{% if services[service_name]['extra_hosts'] is defined %}
    extra_hosts:
{% for additional_hosts in services[service_name].extra_hosts %}
      - {{ additional_hosts }}
{% endfor %}
{% endif %}
    deploy:
      resources:
        limits:
          cpus: "{{ count_cpu }}"
          memory: "{{ count_ram }}"
    logging:
      driver: syslog
      options:
        tag: {%raw%}"docker/{{.Name}}/{{.Name}}"{%endraw%}
{% if services[service_name]['vol'] is defined %}

    volumes:
{% if services[service_name]['vol'] is string %}
      - "{{ services[service_name]['vol'] }}"
{% else %}
{% for volume in services[service_name]['vol'] %}
      - "{{ volume }}"
{% endfor %}
{% endif %}
{% endif %}
{% if services[service_name]['environment'] is defined or 
      (otel_env is defined and services[service_name].get('enable_otel', false)) %}
      
    environment:
{% if services[service_name]['environment'] is defined %}
{% for key, value in services[service_name]['environment'].items() %}
      - {{ key }}={{ value }}
{% endfor %}
{% endif %}
{% if otel_env is defined and services[service_name].get('enable_otel', false) %}
{% for key, value in otel_env.items() %}
      - {{ key }}={{ value }}
{% endfor %}
{% endif %}
{% endif %}
networks:
  default:
    external: true
    name: skynet
{% if services[service_name]['share_external'] is defined %}
volumes:
{{ services[service_name].share_external | to_nice_yaml | indent(2, true) }}
{% endif %}


