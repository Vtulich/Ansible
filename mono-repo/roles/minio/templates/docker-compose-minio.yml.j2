version: '3.7'

services:
  minio-service:
    image: minio/minio
    container_name: minio
    restart: unless-stopped
    logging:
      driver: syslog
      options:
        tag: "{%raw%}docker/{{.Name}}/{{.Name}}{%endraw%}"
    deploy:
        resources:
            limits:
              cpus: '{{ count_cpu }}'
              memory: {{ count_memory }}
    ports:
      - '{{ port_api }}:{{ port_api }}'
      - '{{ port_ui }}:{{ port_ui }}'
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - /etc/timezone:/etc/timezone:ro
      - {{ host_volume }}:{{ docker_volume }}
    command: minio server --address ":{{ port_api }}" --console-address ":{{ port_ui }}" {{ docker_volume }}
    environment:
      - "MINIO_ROOT_USER={{ minio_admin_user }}"
      - "MINIO_ROOT_PASSWORD={{ minio_admin_password }}"
      - "MINIO_SERVER_URL=http://{{ inventory_hostname }}:{{ port_api }}"
      - "MINIO_HTTP_TRACE=/dev/stdout"
      - "MINIO_PROMETHEUS_URL=http://tt2-ftrr01-st03.firm.ru"
      - "MINIO_PROMETHEUS_JOB_ID={{ prometheus_job }}"
      - "MINIO_PROMETHEUS_AUTH_TYPE={{ prometheus_auth_type }}"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://{{ inventory_hostname }}:{{ port_api }}/minio/health/live"]
      interval: 30s
      timeout: 20s
      retries: 3
