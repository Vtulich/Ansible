apiVersion: v1
kind: Secret
metadata:
  name: hyperdx-secrets
type: Opaque
stringData:
  # Строка подключения, которую использует HyperDX для доступа к replica set MongoDB
  MONGO_URI: >-
    mongodb://{{ vault_secrets.mongo_db_username }}:{{ vault_secrets.mongo_db_password }}@mongo-0.mongo-headless.{{ namespace }}.svc.cluster.local:27017,
    mongo-1.mongo-headless.{{ namespace }}.svc.cluster.local:27017,
    mongo-2.mongo-headless.{{ namespace }}.svc.cluster.local:27017/hyperdx?replicaSet=rs0&authSource=admin
  # Секрет для подписи JWT токенов backend’а
  JWT_SECRET: "{{ vault_secrets.hyperdx_jwt_secret }}"
  # Секрет NextAuth (frontend аутентификация)
  NEXTAUTH_SECRET: "{{ vault_secrets.hyperdx_nextauth_secret }}"
  # Секрет нового auth-слоя HyperDX
  AUTH_SECRET: "{{ vault_secrets.hyperdx_auth_secret }}"
  # Ключ шифрования чувствительных данных (интеграционные токены и т.п.)
  ENCRYPTION_KEY: "{{ vault_secrets.hyperdx_encryption_key }}"